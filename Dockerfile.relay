FROM golang:1.24-alpine AS build

WORKDIR /src

COPY relay-go/go.mod ./relay-go/go.mod
COPY relay-go/*.go ./relay-go/

WORKDIR /src/relay-go
RUN go build -o /bin/stream-relay .

FROM alpine:3.20

RUN apk add --no-cache ca-certificates wget

WORKDIR /app

COPY --from=build /bin/stream-relay /usr/local/bin/stream-relay

CMD ["stream-relay"]
