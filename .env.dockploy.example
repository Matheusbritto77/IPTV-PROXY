NODE_ENV=production
APP_BASE_URL=https://renttool.store
APP_PUBLIC_PROTOCOL=https
APP_UPSTREAM_ORIGIN=http://app:8080
STREAM_RELAY_ORIGIN=http://stream-relay:8081
OPENRESTY_APP_ORIGIN=http://app:8080
OPENRESTY_STREAM_RELAY_ORIGIN=http://stream-relay:8081
APP_NAME=P2P Gateway
ADMIN_TOKEN=troque-por-um-token-forte
EDGE_SHARED_SECRET=troque-por-um-segredo-forte
ACCESS_PASSWORD_ENCRYPTION_KEY=troque-por-uma-chave-forte-de-criptografia
SESSION_TTL_SECONDS=300
REQUEST_GUARD_ENABLED=false
IP_ALLOWLIST_ENABLED=false
RATE_LIMIT_WINDOW_SECONDS=30
RATE_LIMIT_MAX_REQUESTS=120
UPSTREAM_TIMEOUT_MS=8000
LIVE_CHANNEL_DRAIN_TTL_MS=15000
LIVE_CHANNEL_RECONNECT_DELAY_MS=1000
LIVE_CHANNEL_READ_CHUNK_BYTES=2048
LIVE_CHANNEL_RING_BUFFER_CHUNKS=32
LIVE_CHANNEL_RING_BUFFER_BYTES=262144
LIVE_CHANNEL_MAX_SUBSCRIBER_BUFFER_BYTES=524288
STREAM_MODE=proxy
BOOTSTRAP_ENABLED=false
BOOTSTRAP_CLIENT_NAME=
BOOTSTRAP_USERNAME=
BOOTSTRAP_PASSWORD=
BOOTSTRAP_EXPIRES_AT=
BOOTSTRAP_MAX_CONNECTIONS=0
BOOTSTRAP_UPSTREAM_NAME=Principal
BOOTSTRAP_UPSTREAM_SMARTERS_URL=
BOOTSTRAP_UPSTREAM_XCIPTV_DNS=
BOOTSTRAP_UPSTREAM_USERNAME=
BOOTSTRAP_UPSTREAM_PASSWORD=
