NODE_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:8090
APP_PUBLIC_PROTOCOL=auto
PREFERRED_LIVE_FORMAT=auto
PREFERRED_VOD_FORMAT=auto
APP_UPSTREAM_ORIGIN=http://app:8080
STREAM_RELAY_ORIGIN=http://stream-relay:8081
OPENRESTY_APP_ORIGIN=http://app:8080
OPENRESTY_STREAM_RELAY_ORIGIN=http://stream-relay:8081
APP_NAME=P2P Gateway
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/p2p_gateway
REDIS_URL=redis://localhost:6379
SESSION_TTL_SECONDS=300
REQUEST_GUARD_ENABLED=false
IP_ALLOWLIST_ENABLED=false
RATE_LIMIT_WINDOW_SECONDS=30
RATE_LIMIT_MAX_REQUESTS=120
UPSTREAM_TIMEOUT_MS=8000
UPSTREAM_MAX_IDLE_CONNECTIONS=256
UPSTREAM_MAX_CONNECTIONS_PER_HOST=128
UPSTREAM_IDLE_TIMEOUT_MS=90000
UPSTREAM_TLS_HANDSHAKE_TIMEOUT_MS=5000
STREAM_MODE=proxy
ADMIN_TOKEN=change-me
EDGE_SHARED_SECRET=change-me-edge-secret
ACCESS_PASSWORD_ENCRYPTION_KEY=change-me-access-password-key
OPENRESTY_PORT=8090
STREAM_RELAY_PORT=8081
STREAM_RELAY_REQUEST_TIMEOUT_MS=12000
STREAM_RELAY_MAX_IDLE_CONNS=512
STREAM_RELAY_MAX_IDLE_CONNS_PER_HOST=256
STREAM_RELAY_MAX_CONNS_PER_HOST=256
STREAM_RELAY_IDLE_CONN_TIMEOUT_MS=90000
STREAM_RELAY_RESPONSE_HEADER_TIMEOUT_MS=10000
STREAM_RELAY_TLS_HANDSHAKE_TIMEOUT_MS=5000

BOOTSTRAP_ENABLED=false
BOOTSTRAP_CLIENT_NAME=Cliente Demo
BOOTSTRAP_USERNAME=demo_user
BOOTSTRAP_PASSWORD=change-me-demo-password
BOOTSTRAP_EXPIRES_AT=2026-12-31T00:00:00.000Z
BOOTSTRAP_MAX_CONNECTIONS=1
BOOTSTRAP_UPSTREAM_NAME=Demo Upstream
BOOTSTRAP_UPSTREAM_SMARTERS_URL=http://localhost:8088
BOOTSTRAP_UPSTREAM_XCIPTV_DNS=http://localhost:8088
BOOTSTRAP_UPSTREAM_USERNAME=upstream_user
BOOTSTRAP_UPSTREAM_PASSWORD=upstream_password
